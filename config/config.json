{
  "metadata": {
    "config_version": "0.1",
    "created_date": "2026-04-29",
    "description": "Bayesian Borrowing Analysis Configuration generated from spec/analysis_spec.R",
    "status": "statistical-design-validation"
  },
  "model": {
    "model_name": "borrowing_v1",
    "outcome_type": "multi-outcome",
    "outcome_types": ["binary", "continuous", "survival"]
  },
  "borrowing": {
    "method": "fixed_power_prior_weight",
    "a0": 0.5
  },
  "weighting": {
    "use_ps_weight": true,
    "trim_lower": 0.01,
    "trim_upper": 0.99
  },
  "survival": {
    "cut_points": [6, 12, 18, 24, 30]
  },
  "mcmc": {
    "chains": 4,
    "iter": 2000,
    "warmup": 1000,
    "seed": 20260407
  },
  "diagnostics": {
    "rhat_threshold": 1.05,
    "ess_bulk_min": 400,
    "ess_tail_min": 400,
    "divergent_allowed": 0,
    "stop_on_failure": true
  },
  "output": {
    "save_warmup": false,
    "output_dir": "outputs"
  },
  "paths": {
    "config_path": "config/config.json",
    "models_dir": "models",
    "data_dir": "data",
    "outputs_dir": "outputs",
    "cmdstan_output_dir": "outputs/cmdstan",
    "stan_input_files": {
      "binary": "stan_input_binary.json",
      "continuous": "stan_input_continuous.json",
      "survival": "stan_input_survival.json"
    },
    "model_files": {
      "binary": "binary.stan",
      "continuous": "continuous.stan",
      "survival": "survival.stan"
    },
    "output_files": {
      "summary": "summary_output.json",
      "metadata": "metadata.json",
      "diagnostics": "diagnostics.json"
    }
  }
}
